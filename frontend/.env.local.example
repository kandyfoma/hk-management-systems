# Local Development Environment Variables
# Copy to .env.local for local development
# Keep .env.local in .gitignore - DO NOT commit to version control

# ===== APPLICATION ENVIRONMENT =====
REACT_APP_ENV=development

# ===== API CONFIGURATION =====
# For local development, point to your local backend or staging server
REACT_APP_API_URL=http://localhost:8000

# For connecting to remote staging server:
# REACT_APP_API_URL=https://api-staging.katohms.com

# ===== OPTIONAL: SERVICES =====
# Add your local service URLs and credentials here

# Firebase (for development)
# REACT_APP_FIREBASE_API_KEY=your_dev_key
# REACT_APP_FIREBASE_AUTH_DOMAIN=your_dev_domain

# Sentry (optional for development error tracking)
# REACT_APP_SENTRY_DSN=https://your-key@sentry.io/project-id

# ===== FEATURE FLAGS - DEVELOPMENT =====
# Enable debug logging for development
REACT_APP_ENABLE_DEBUG_LOGS=true

# Enable offline mode testing
REACT_APP_ENABLE_OFFLINE_MODE=false

# ===== DEBUGGING =====
# Uncomment to enable debug output in console
# DEBUG=*
