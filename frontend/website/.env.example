# Next.js Environment Variables
# Copy this file to .env.local and update with your actual values

# Application Settings
NEXT_PUBLIC_APP_URL=https://www.katohms.com
NEXT_PUBLIC_APP_ENV=production

# Third-party Services (if needed)
# NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id_here
# NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# Backend API (if connecting to backend)
# NEXT_PUBLIC_API_URL=https://api.katohms.com

# Note: Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# Do NOT add sensitive credentials (API keys, tokens) without the NEXT_PUBLIC_ prefix.
