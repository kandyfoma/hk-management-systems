# Vercel Build Ignore File
# Files and directories to exclude from Vercel deployments

# Git
.git
.gitignore

# Dependencies (will be reinstalled)
node_modules

# Build artifacts
.expo
.next
dist
build
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files (use Vercel dashboard instead)
.env
.env.local
.env.*.local
.env.*.example

# IDE/Editor
.vscode
.idea
*.swp
*.swo
*~
.DS_Store

# Documentation (optional to exclude)
# *.md
README.md
TESTING_GUIDE.md
CODE_PATTERNS.md

# Testing
__tests__
__mocks__
jest.config.js
*.test.js
*.test.ts
*.test.tsx

# Scripts
scripts/

# Temp files
tmp/
temp/
*.tmp

# OS
.DS_Store
Thumbs.db
