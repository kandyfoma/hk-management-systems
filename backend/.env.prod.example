# =============================================================================
# .env.prod.example — Production Environment Variables for Railway
# Copy to Railway Variables and fill in real values
# =============================================================================

# Django Core
SECRET_KEY=change-me-to-a-strong-random-secret-key-here
DEBUG=False
ALLOWED_HOSTS=api.katms.org,localhost,127.0.0.1

# Railway PostgreSQL (auto-configured when adding PostgreSQL plugin)
# Just set this variable to the PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Legacy DB Config (used if DATABASE_URL not set)
DB_NAME=hk_management
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# CORS & CSRF (comma-separated, required for frontend)
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://app.katms.org,https://www.katms.org
CSRF_TRUSTED_ORIGINS=https://app.katms.org,https://www.katms.org

# Security (Production)
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Redis Cache (Optional—only if you add Redis service)
# REDIS_URL=redis://redis:6379/0

# Email Configuration (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=KAT Management <noreply@katms.org>

# AI Features (Optional—Gemini API)
# GEMINI_API_KEY=sk-your-gemini-api-key-here
